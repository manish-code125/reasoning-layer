#!/usr/bin/env python3
# Reasoning Layer — Coherence Pre-Commit Hook
#
# Checks staged files against tracked artifact decisions before every commit.
# If a tracked file has a linked decision that's newer than the file's last commit,
# it means code may not yet reflect the decision.
#
# Configure via environment variables:
#   REASONING_LAYER_BACKEND  — backend URL (default: http://44.200.186.86/reasoning)
#   REASONING_LAYER_MODE     — "warn" (default) or "block"
#
# warn:  prints drift warnings, commit proceeds
# block: exits 1 if any drifted file is staged — commit is prevented

import json
import os
import subprocess
import sys
import urllib.request

BACKEND = os.environ.get("REASONING_LAYER_BACKEND", "http://44.200.186.86/reasoning")
MODE = os.environ.get("REASONING_LAYER_MODE", "warn")


def run(cmd):
    return subprocess.check_output(cmd, text=True).strip()


def main():
    repo_path = run(["git", "rev-parse", "--show-toplevel"])

    staged_raw = run(["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"])
    staged_files = [f for f in staged_raw.splitlines() if f]
    if not staged_files:
        sys.exit(0)

    file_timestamps = {}
    for f in staged_files:
        ts = run(["git", "log", "-1", "--format=%cI", "--", f])
        file_timestamps[f] = ts if ts else "1970-01-01T00:00:00Z"

    body = json.dumps({"repo_path": repo_path, "file_timestamps": file_timestamps}).encode()
    req = urllib.request.Request(
        f"{BACKEND}/api/artifacts/drift",
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        resp = json.loads(urllib.request.urlopen(req, timeout=5).read())
    except Exception:
        sys.exit(0)  # backend unreachable — never block commits

    drifted = resp.get("drifted", [])
    if not drifted:
        sys.exit(0)

    print("\n⚠  Reasoning Layer: staged files have decisions that may not be reflected in the code\n")
    for item in drifted:
        d = item["latest_decision"]
        file_date = item.get("file_last_committed_at", "")[:10]
        decision_date = d.get("created_at", "")[:10]
        print(f"  {item['file_path']}")
        print(f"    [{d['hex_id']}] {d['question_text']}")
        print(f"    → {d['answer']}")
        print(f"    decision: {decision_date}  |  file last committed: {file_date}")
        print()

    if MODE == "block":
        print("Commit blocked. Resolve the drift above, then re-run git commit.")
        print("  Option 1: Update the file to reflect the decision.")
        print("  Option 2: Add a rollback WAL entry if the decision needs revisiting.")
        print()
        sys.exit(1)
    else:
        print("Commit proceeding (warn mode). Set REASONING_LAYER_MODE=block to enforce.\n")


if __name__ == "__main__":
    main()
